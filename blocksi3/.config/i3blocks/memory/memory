#!/usr/bin/python3
import subprocess


def parse_h(value: str) -> float:
    if value.endswith('G'):
        return float(value[:-1].replace(',', '.'))
    if value.endswith('M'):
        return float(value[:-1].replace(',', '.')) / 1024
    if value.endswith('T'):
        return float(value[:-1].replace(',', '.')) * 1024
    return 0.0


def main() -> int:
    # Get disk usage
    try:
        df = subprocess.run(
            ['df', '-h'],
            capture_output=True,
            text=True,
            check=True
        )
    except subprocess.CalledProcessError:
        print("Error running df")
        return 1

    lines = df.stdout.strip().splitlines()[1:]
    total_gb = 0.0
    used_gb = 0.0

    for line in lines:
        parts = line.split()
        if len(parts) < 6:
            continue
        source, size, used, target = parts[0], parts[1], parts[2], parts[5]

        # Include physical partitions (/dev/...), but exclude boot partition
        if (source.startswith('/dev/') and
                not source.startswith('/dev/loop') and
                target != '/boot/efi'):
            total_gb += parse_h(size)
            used_gb += parse_h(used)

    # Get swap size
    try:
        swap = subprocess.run(
            ['swapon', '--show=SIZE', '--bytes', '--noheadings'],
            capture_output=True,
            text=True
        )
        swap_val = 0.0
        for s_line in swap.stdout.strip().splitlines():
            if s_line.strip():
                swap_val += float(s_line.strip()) / (1024**3)
    except (FileNotFoundError, subprocess.CalledProcessError, ValueError):
        swap_val = 0.0

    # Subtract swap from both as per previous logic
    # (assuming swap is a file on disk)
    final_used = int(used_gb - swap_val)
    final_total = int(total_gb - swap_val)

    print(f"{max(0, final_used)}G/{max(0, final_total)}G")
    return 0


if __name__ == '__main__':
    main()
